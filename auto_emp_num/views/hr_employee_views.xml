<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_auto_number" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.auto.number</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_generate_numbers_by_seniority" 
                        string="Numerar por Antigüedad" 
                        type="object" 
                        class="btn-primary"
                        groups="hr.group_hr_manager"
                        confirm="Se asignarán números EMPxxxxx basados en la fecha de contrato. ¿Deseas continuar con los 97 registros?"/>
            </xpath>

            # 

            <xpath expr="//field[@name='mobile_phone']" position="before">
                <field name="registration_number" readonly="1" force_save="1" string="ID Empleado"/>
            </xpath>

            <xpath expr="//field[@name='pin']" position="attributes">
                <attribute name="password">False</attribute> <attribute name="readonly">1</attribute>
            </xpath>

        </field>
    </record>
</odoo>
